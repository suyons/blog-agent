# blog-agent configuration — copy to .env and fill in your own values.
#   cp .env.example .env
# .env is gitignored; it holds host-specific paths and your webhook URL.
# Never commit real values, secrets, or personal identifiers.

# --- Discord notification ---------------------------------------------------
# Webhook that receives ONE message per run (status + slug/reason), POSTed
# directly to Discord. Leave blank to disable notifications.
DISCORD_WEBHOOK_URL=

# --- Host paths (absolute; $HOME is expanded) -------------------------------
# Private note vault (git repo) the agent reads yesterday's diff from.
NOTE_REPO=$HOME/note
# Public Hugo blog repo the agent drafts posts into (on the `draft` branch).
BLOG_REPO=$HOME/your-blog.github.io
# This agent's own checkout (where logs/ and BLOG_GUIDE.md live).
AGENT_DIR=$HOME/blog-agent

# --- GitHub (for opening the draft -> main PR on the blog repo) -------------
# Owner + repo name used with the REST API. The PAT itself is read from the
# local git credential store at run time and is NEVER stored here.
GITHUB_OWNER=your-github-username
BLOG_REPO_NAME=your-blog.github.io

# --- Model ------------------------------------------------------------------
BLOG_WRITER_MODEL=claude-opus-4-8
